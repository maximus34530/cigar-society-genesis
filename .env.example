# Optional: canonical / OG URLs (default: https://cigarsocietyus.com)
# VITE_SITE_ORIGIN=https://cigarsocietyus.com

# Optional: Plausible Analytics (domain only, e.g. cigarsocietyus.com)
# VITE_PLAUSIBLE_DOMAIN=

# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# VITE_GA_MEASUREMENT_ID=

# Phase 2: Supabase (client-safe — use anon or publishable key, never service role)
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
